<?xml version="1.0" encoding="UTF-8"?>
<validation>
    <field name="id">
        <condition expression="#update">
            <rule type="NonNullRule"/>
        </condition>
    </field>

    <field name="message">
        <condition expression="#createOrUpdate">
            <rule type="NotBlankRule"/>
        </condition>
    </field>

    <field name="status">
        <condition expression="#create">
            <rule type="NonNullRule"/>
        </condition>
    </field>

</validation>
